<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <link rel="stylesheet" href="_content/SportVitaal.Shared/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="_content/SportVitaal.Shared/app.css"/>
    <link rel="stylesheet" href="SportVitaal.Web.styles.css"/>
    <ImportMap/>
    <link rel="icon" type="image/png" href="_content/SportVitaal.Shared/favicon.png"/>
    <HeadOutlet @rendermode="InteractiveServer"/>
</head>

<body>
<Routes @rendermode="InteractiveServer" AdditionalAssemblies="WebAssemblies"/>
<ReconnectModal/>
<script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    // Make the Web project's own pages (public + admin) routable alongside the Shared pages.
    private static readonly System.Reflection.Assembly[] WebAssemblies = { typeof(App).Assembly };
}