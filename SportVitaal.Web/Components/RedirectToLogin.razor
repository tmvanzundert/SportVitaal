@inject NavigationManager Navigation

@code {
    // Navigate only after the first interactive render so we don't redirect during prerender
    // (when the auth token hasn't been restored from session storage yet).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var returnUrl = Uri.EscapeDataString(Navigation.ToBaseRelativePath(Navigation.Uri));
            Navigation.NavigateTo($"medewerker/login?returnUrl={returnUrl}", forceLoad: false);
        }
        await Task.CompletedTask;
    }
}
