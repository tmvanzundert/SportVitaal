@page "/medewerker/leden"
@layout AdminLayout
@inject SportVitaalApiClient Api

<PageTitle>Leden</PageTitle>

<h1 class="h3">Leden</h1>
<p>Alle leden en hun lidmaatschapsstatus.</p>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_loading)
{
    <p><em>Laden…</em></p>
}
else if (_members.Count == 0)
{
    <p>Er zijn nog geen leden.</p>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr><th>E-mail</th><th>Naam</th><th>Abonnement</th><th>Status</th><th>Periode</th></tr>
        </thead>
        <tbody>
            @foreach (var m in _members)
            {
                <tr>
                    <td>@m.Email</td>
                    <td>@(string.IsNullOrWhiteSpace(m.FullName) ? "-" : m.FullName)</td>
                    <td>@(m.Membership is null ? "—" : Describe(m.Membership.Type))</td>
                    <td>
                        @if (m.Membership is null)
                        {
                            <span class="badge bg-secondary">geen</span>
                        }
                        else if (m.Membership.IsActive)
                        {
                            <span class="badge bg-success">actief</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">verlopen</span>
                        }
                    </td>
                    <td>
                        @if (m.Membership is not null)
                        {
                            @m.Membership.StartDate.ToString("d MMM yyyy")
                            <text> – </text>
                            @(m.Membership.EndDate?.ToString("d MMM yyyy") ?? "doorlopend")
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<MemberDto> _members = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try { _members = await Api.GetMembersAsync(); }
        catch { _error = "Kon de ledenlijst niet laden."; }
        finally { _loading = false; }
    }

    private static string Describe(string type) => type switch
    {
        "TwiceWeeklyMonthly" => "Max 2x per week (maand)",
        "TwiceWeeklyYearly" => "Max 2x per week (jaar)",
        "UnlimitedMonthly" => "Onbeperkt (maand)",
        "UnlimitedYearly" => "Onbeperkt (jaar)",
        _ => type
    };
}
