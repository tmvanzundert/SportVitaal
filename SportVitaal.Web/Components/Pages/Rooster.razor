@page "/rooster"
@inject SportVitaalApiClient Api

<PageTitle>Rooster</PageTitle>

<h1>Rooster</h1>
<p>Onze lessen voor de komende periode.</p>

@if (_loading)
{
    <p><em>Laden…</em></p>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_lessons.Count == 0)
{
    <p>Er staan momenteel geen lessen gepland.</p>
}
else
{
    @foreach (var day in _lessons.GroupBy(l => l.StartAt.Date).OrderBy(g => g.Key))
    {
        <h2 class="h5 mt-4">@day.Key.ToString("dddd d MMMM yyyy")</h2>
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Tijd</th>
                    <th>Workout</th>
                    <th>Locatie</th>
                    <th>Instructeur</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lesson in day.OrderBy(l => l.StartAt))
                {
                    <tr>
                        <td>@lesson.StartAt.ToString("HH:mm") – @lesson.StartAt.AddMinutes(lesson.DurationMinutes).ToString("HH:mm")</td>
                        <td>@WorkoutName(lesson.WorkoutId)</td>
                        <td>@(lesson.Location?.Name ?? "-")</td>
                        <td>@InstructorCell(lesson.InstructorId)</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<LessonDto> _lessons = new();
    private Dictionary<Guid, WorkoutDto> _workouts = new();
    private Dictionary<Guid, InstructorDto> _instructors = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var lessonsTask = Api.GetLessonsAsync();
            var workoutsTask = Api.GetWorkoutsAsync();
            var instructorsTask = Api.GetInstructorsAsync();
            await Task.WhenAll(lessonsTask, workoutsTask, instructorsTask);

            _lessons = lessonsTask.Result;
            _workouts = workoutsTask.Result.ToDictionary(w => w.Id);
            _instructors = instructorsTask.Result.ToDictionary(i => i.Id);
        }
        catch
        {
            _error = "Het rooster kon niet worden geladen. Probeer het later opnieuw.";
        }
        finally
        {
            _loading = false;
        }
    }

    private string WorkoutName(Guid workoutId)
        => _workouts.TryGetValue(workoutId, out var w) ? w.Name : "Onbekend";

    private RenderFragment InstructorCell(Guid? instructorId) => builder =>
    {
        if (instructorId is { } id && _instructors.TryGetValue(id, out var instructor))
        {
            if (!string.IsNullOrWhiteSpace(instructor.PhotoUrl))
            {
                builder.OpenElement(0, "img");
                builder.AddAttribute(1, "src", $"{Api.ApiBaseUrl}{instructor.PhotoUrl}");
                builder.AddAttribute(2, "alt", instructor.Name);
                builder.AddAttribute(3, "class", "rounded-circle me-2");
                builder.AddAttribute(4, "style", "width:32px;height:32px;object-fit:cover;");
                builder.CloseElement();
            }
            builder.AddContent(5, instructor.Name);
        }
        else
        {
            builder.AddContent(6, "nnb");
        }
    };
}
