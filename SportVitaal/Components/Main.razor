@using SportVitaal.Services
@inject ApiClient Api
@inject NavigationManager Nav
@implements IDisposable

@if (!_ready)
{
    <div class="splash">Sport Vitaal</div>
}
else if (Api.IsLoggedIn)
{
    <Routes />
}
else
{
    <Login />
}

@code {
    private bool _ready;

    protected override async Task OnInitializedAsync()
    {
        Api.Changed += OnChanged;
        await Api.InitializeAsync();
        _ready = true;
    }

    private void OnChanged() => InvokeAsync(() =>
    {
        // After logout the NavigationManager still points at the deep page the user
        // signed out from (e.g. /profiel). Reset to the root so the next login lands
        // on the dashboard rather than re-routing to that stale URL.
        if (_ready && !Api.IsLoggedIn && !string.IsNullOrEmpty(Nav.ToBaseRelativePath(Nav.Uri)))
            Nav.NavigateTo("");

        StateHasChanged();
    });

    public void Dispose() => Api.Changed -= OnChanged;
}
