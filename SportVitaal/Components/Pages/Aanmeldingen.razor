@page "/aanmeldingen"
@inject SportVitaal.ViewModels.InstructorLessonsViewModel Vm
@inject NavigationManager Nav
@implements IDisposable

<div class="screen">
    <header class="head">
        <button class="back" @onclick='() => Nav.NavigateTo("")' aria-label="Terug">←</button>
        <div>
            <h1>Aanmeldingen</h1>
            <p class="sub">Jouw lessen</p>
        </div>
    </header>

    @if (!Vm.Loaded)
    {
        <p class="muted">Laden…</p>
    }
    else if (Vm.Count == 0)
    {
        <p class="empty">Je hebt geen geplande lessen.</p>
    }
    else
    {
        <h3 class="section">@Vm.Count @(Vm.Count == 1 ? "les" : "lessen")</h3>
        @foreach (var lesson in Vm.Lessons)
        {
            <div class="card lesson clickable" @onclick='() => Nav.NavigateTo($"aanmeldingen/{lesson.LessonId}")'>
                <span class="lesson-icon">📋</span>
                <div class="lesson-body">
                    <strong>@lesson.Workout</strong>
                    <span class="muted">@lesson.When · @lesson.Location</span>
                </div>
                <span class="att"><span class="att-count">@lesson.Attendance</span><br/><span class="muted">aanwezig</span></span>
            </div>
        }
    }
</div>

@code {
    // Blazor does not observe INotifyPropertyChanged, so bridge view model changes to a re-render.
    protected override void OnInitialized() => Vm.PropertyChanged += OnViewModelChanged;

    protected override async Task OnInitializedAsync() => await Vm.LoadCommand.ExecuteAsync(null);

    private void OnViewModelChanged(object? sender, PropertyChangedEventArgs e) => InvokeAsync(StateHasChanged);

    public void Dispose() => Vm.PropertyChanged -= OnViewModelChanged;
}
