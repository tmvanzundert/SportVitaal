@page "/abonnementen"

<PageTitle>Abonnementen</PageTitle>

<h1>Abonnementen</h1>
<p>Kies het abonnement dat bij je past en word vandaag nog lid.</p>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3">
    @foreach (var plan in Plans)
    {
        <div class="col">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@plan.Title</h5>
                    <p class="display-6">&euro;@plan.Price</p>
                    <p class="text-muted">@plan.Period</p>
                    <a class="btn btn-success mt-auto" href="@($"aanmelden?plan={plan.Type}")">Word lid</a>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private record Plan(MembershipType Type, string Title, decimal Price, string Period);

    // Prices mirror the WebApi (MembershipsController).
    private static readonly Plan[] Plans =
    {
        new(MembershipType.TwiceWeeklyMonthly, "Max 2x per week", 29m, "per maand"),
        new(MembershipType.TwiceWeeklyYearly, "Max 2x per week", 299m, "per jaar"),
        new(MembershipType.UnlimitedMonthly, "Onbeperkt sporten", 55m, "per maand"),
        new(MembershipType.UnlimitedYearly, "Onbeperkt sporten", 549m, "per jaar"),
    };
}
