@page "/medewerker/instructeurs"
@layout AdminLayout
@inject SportVitaalApiClient Api

<PageTitle>Instructeurs beheren</PageTitle>

<h1 class="h3">Instructeurs</h1>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h5">@(_editId is null ? "Nieuwe instructeur" : "Instructeur bewerken")</h2>
        <div class="row g-2">
            <div class="col-md-6"><input class="form-control" placeholder="Naam" @bind="_name"/></div>
            @if (_editId is null)
            {
                <div class="col-md-6"><input class="form-control" type="email" placeholder="E-mailadres" @bind="_email"/></div>
            }
            <div class="col-md-6 d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">@(_editId is null ? "Toevoegen" : "Opslaan")</button>
                @if (_editId is not null)
                {
                    <button class="btn btn-outline-secondary" @onclick="CancelEdit">Annuleren</button>
                }
            </div>
        </div>
        <p class="text-muted small mt-2 mb-0">
            @(_editId is null
                ? "De instructeur krijgt een eigen inlogaccount met de rol instructeur. Een wachtwoord wordt automatisch gegenereerd en per e-mail verstuurd. Een foto kun je na het toevoegen uploaden in de lijst hieronder."
                : "Een foto kun je per instructeur uploaden in de lijst hieronder.")
        </p>
    </div>
</div>

@if (_loading)
{
    <p><em>Laden…</em></p>
}
else
{
    <table class="table align-middle">
        <thead><tr><th>Foto</th><th>Naam</th><th>E-mailadres</th><th></th></tr></thead>
        <tbody>
            @foreach (var i in _instructors)
            {
                <tr>
                    <td style="width:64px">
                        @if (!string.IsNullOrWhiteSpace(i.PhotoUrl))
                        {
                            <img src="@($"{Api.ApiBaseUrl}{i.PhotoUrl}")" alt="@i.Name" class="rounded-circle" style="width:48px;height:48px;object-fit:cover;"/>
                        }
                        else
                        {
                            <span class="text-muted small">geen</span>
                        }
                    </td>
                    <td>@i.Name</td>
                    <td>@(string.IsNullOrWhiteSpace(i.Email) ? "—" : i.Email)</td>
                    <td class="text-end">
                        <label class="btn btn-sm btn-outline-secondary mb-0">
                            Foto
                            <InputFile OnChange="@(e => UploadPhotoAsync(e, i.Id))" accept="image/*" hidden/>
                        </label>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => BeginEdit(i)">Bewerken</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(i)">Verwijderen</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private const long MaxPhotoBytes = 5 * 1024 * 1024;

    private List<InstructorDto> _instructors = new();
    private bool _loading = true;
    private bool _busy;
    private string? _error;

    private Guid? _editId;
    private string _name = string.Empty;
    private string _email = string.Empty;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try { _instructors = await Api.GetInstructorsAsync(); _error = null; }
        catch { _error = "Kon instructeurs niet laden."; }
        finally { _loading = false; }
    }

    private void BeginEdit(InstructorDto i)
    {
        _editId = i.Id;
        _name = i.Name;
    }

    private void CancelEdit()
    {
        _editId = null;
        _name = string.Empty;
        _email = string.Empty;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_name)) { _error = "Naam is verplicht."; return; }

        if (_editId is null)
        {
            if (string.IsNullOrWhiteSpace(_email)) { _error = "E-mailadres is verplicht."; return; }
        }

        _busy = true;
        try
        {
            if (_editId is null)
            {
                var (ok, error) = await Api.CreateInstructorAsync(_name, _email);
                if (!ok) { _error = string.IsNullOrWhiteSpace(error) ? "Opslaan mislukt." : error; return; }
            }
            else if (!await Api.UpdateInstructorAsync(_editId.Value, _name))
            {
                _error = "Opslaan mislukt.";
                return;
            }

            _error = null;
            CancelEdit();
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task UploadPhotoAsync(InputFileChangeEventArgs e, Guid instructorId)
    {
        var file = e.File;
        if (file is null) return;
        if (file.Size > MaxPhotoBytes) { _error = "De foto mag maximaal 5 MB zijn."; return; }

        try
        {
            await using var stream = file.OpenReadStream(MaxPhotoBytes);
            var ok = await Api.UploadInstructorPhotoAsync(instructorId, stream, file.Name, file.ContentType);
            if (!ok) { _error = "Foto uploaden mislukt (controleer het bestandstype)."; return; }
            _error = null;
            await LoadAsync();
        }
        catch
        {
            _error = "Foto uploaden mislukt.";
        }
    }

    private async Task DeleteAsync(InstructorDto i)
    {
        if (!await Api.DeleteInstructorAsync(i.Id)) { _error = "Verwijderen mislukt."; return; }
        await LoadAsync();
    }
}
