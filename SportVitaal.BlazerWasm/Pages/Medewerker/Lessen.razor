@page "/medewerker/lessen"
@layout AdminLayout
@inject SportVitaalApiClient Api

<PageTitle>Lessen beheren</PageTitle>

<h1 class="h3">Lessen</h1>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

<div class="card mb-4">
    <div class="card-body">
        <h2 class="h5">@(_editId is null ? "Nieuwe les" : "Les bewerken")</h2>

        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label">Workout</label>
                <select class="form-select" @bind="_workoutId" disabled="@(_editId is not null)">
                    <option value="">— kies —</option>
                    @foreach (var w in _workouts)
                    {
                        <option value="@w.Id">@w.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Locatie</label>
                <select class="form-select" @bind="_locationId">
                    <option value="">— kies —</option>
                    @foreach (var l in _locations)
                    {
                        <option value="@l.Id">@l.Name (cap. @l.Capacity)</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Instructeur</label>
                <select class="form-select" @bind="_instructorId">
                    <option value="">nnb (nog niet bekend)</option>
                    @foreach (var i in _instructors)
                    {
                        <option value="@i.Id">@i.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Startdatum</label>
                <input class="form-control" type="date" @bind="StartDateValue"/>
            </div>
            <div class="col-md-2">
                <label class="form-label">Starttijd</label>
                <select class="form-select" @bind="StartTimeValue">
                    @foreach (var t in TimeOptions)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Duur (min)</label>
                <input class="form-control" type="number" min="1" @bind="_duration"/>
            </div>
        </div>

        @if (_editId is null)
        {
            <div class="form-check mt-3">
                <input class="form-check-input" type="checkbox" id="recur" @bind="_recurring"/>
                <label class="form-check-label" for="recur">Herhalen</label>
            </div>

            @if (_recurring)
            {
                <div class="row g-2 mt-1">
                    <div class="col-md-3">
                        <label class="form-label">Frequentie</label>
                        <select class="form-select" @bind="_frequency">
                            <option value="@RecurrenceFrequency.Daily">Per dag</option>
                            <option value="@RecurrenceFrequency.Weekly">Per week</option>
                            <option value="@RecurrenceFrequency.Monthly">Per maand</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Interval</label>
                        <input class="form-control" type="number" min="1" @bind="_interval"/>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Einde</label>
                        <select class="form-select" @bind="_endByDate">
                            <option value="true">Op datum</option>
                            <option value="false">Aantal keer</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        @if (_endByDate)
                        {
                            <label class="form-label">Einddatum</label>
                            <input class="form-control" type="date" @bind="_until"/>
                        }
                        else
                        {
                            <label class="form-label">Aantal herhalingen</label>
                            <input class="form-control" type="number" min="1" @bind="_count"/>
                        }
                    </div>
                </div>
            }
        }

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">@(_editId is null ? "Toevoegen" : "Opslaan")</button>
            @if (_editId is not null)
            {
                <button class="btn btn-outline-secondary" @onclick="CancelEdit">Annuleren</button>
            }
        </div>
    </div>
</div>

@if (_loading)
{
    <p><em>Laden…</em></p>
}
else
{
    <table class="table align-middle">
        <thead><tr><th>Datum &amp; tijd</th><th>Workout</th><th>Locatie</th><th>Instructeur</th><th></th></tr></thead>
        <tbody>
            @foreach (var lesson in _lessons.OrderBy(l => l.StartAt))
            {
                <tr>
                    <td>@lesson.StartAt.ToLocalTime().ToString("ddd d MMM HH:mm")</td>
                    <td>@WorkoutName(lesson.WorkoutId)</td>
                    <td>@(lesson.Location?.Name ?? "-")</td>
                    <td>@InstructorName(lesson.InstructorId)</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => BeginEdit(lesson)">Bewerken</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(lesson)">Verwijderen</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<LessonDto> _lessons = new();
    private List<WorkoutDto> _workouts = new();
    private List<InstructorDto> _instructors = new();
    private List<LocationDto> _locations = new();
    private Dictionary<Guid, string> _workoutNames = new();
    private Dictionary<Guid, string> _instructorNames = new();

    private bool _loading = true;
    private bool _busy;
    private string? _error;

    private Guid? _editId;
    private string _workoutId = string.Empty;
    private string _locationId = string.Empty;
    private string _instructorId = string.Empty;
    private DateTime _startAt = DateTime.Today.AddHours(9);
    private int _duration = 60;

    // The native datetime-local picker renders AM/PM based on the browser's locale,
    // which we can't control. Split it into a date input and a 24-hour time dropdown
    // so the time is always shown in Dutch (24-hour) notation.
    private static readonly string[] TimeOptions =
        Enumerable.Range(0, 24 * 4).Select(i => $"{i / 4:00}:{i % 4 * 15:00}").ToArray();

    private DateOnly StartDateValue
    {
        get => DateOnly.FromDateTime(_startAt);
        set => _startAt = value.ToDateTime(TimeOnly.FromDateTime(_startAt));
    }

    private string StartTimeValue
    {
        get => _startAt.ToString("HH:mm");
        set { if (TimeSpan.TryParse(value, out var t)) _startAt = _startAt.Date + t; }
    }

    private bool _recurring;
    private RecurrenceFrequency _frequency = RecurrenceFrequency.Weekly;
    private int _interval = 1;
    private bool _endByDate = true;
    private DateTime _until = DateTime.Today.AddMonths(1);
    private int _count = 10;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var lessonsTask = Api.GetLessonsAsync(DateTime.Today.AddDays(-7), DateTime.Today.AddDays(60));
            var workoutsTask = Api.GetWorkoutsAsync();
            var instructorsTask = Api.GetInstructorsAsync();
            var locationsTask = Api.GetLocationsAsync();
            await Task.WhenAll(lessonsTask, workoutsTask, instructorsTask, locationsTask);

            _lessons = lessonsTask.Result;
            _workouts = workoutsTask.Result;
            _instructors = instructorsTask.Result;
            _locations = locationsTask.Result;
            _workoutNames = _workouts.ToDictionary(w => w.Id, w => w.Name);
            _instructorNames = _instructors.ToDictionary(i => i.Id, i => i.Name);
            _error = null;
        }
        catch { _error = "Kon de lesgegevens niet laden."; }
        finally { _loading = false; }
    }

    private string WorkoutName(Guid id) => _workoutNames.TryGetValue(id, out var n) ? n : "Onbekend";
    private string InstructorName(Guid? id) => id is { } gid && _instructorNames.TryGetValue(gid, out var n) ? n : "nnb";

    private void BeginEdit(LessonDto l)
    {
        _editId = l.Id;
        _workoutId = l.WorkoutId.ToString();
        _locationId = l.Location?.Id.ToString() ?? string.Empty;
        _instructorId = l.InstructorId?.ToString() ?? string.Empty;
        _startAt = l.StartAt.ToLocalTime();
        _duration = l.DurationMinutes;
        _recurring = false;
    }

    private void CancelEdit()
    {
        _editId = null;
        _workoutId = string.Empty;
        _locationId = string.Empty;
        _instructorId = string.Empty;
        _startAt = DateTime.Today.AddHours(9);
        _duration = 60;
        _recurring = false;
    }

    private async Task SaveAsync()
    {
        if (!Guid.TryParse(_locationId, out var locationId) || _duration <= 0)
        {
            _error = "Locatie en een positieve duur zijn verplicht.";
            return;
        }
        Guid? instructorId = Guid.TryParse(_instructorId, out var iid) ? iid : null;

        _busy = true;
        try
        {
            bool ok;
            if (_editId is not null)
            {
                ok = await Api.UpdateLessonAsync(_editId.Value, locationId, _startAt, _duration, instructorId);
            }
            else
            {
                if (!Guid.TryParse(_workoutId, out var workoutId))
                {
                    _error = "Kies een workout.";
                    return;
                }

                if (_recurring)
                {
                    var until = _endByDate ? _until : (DateTime?)null;
                    var count = _endByDate ? (int?)null : _count;
                    ok = await Api.CreateRecurringLessonAsync(workoutId, locationId, _startAt, _duration, instructorId, _frequency, _interval, until, count);
                }
                else
                {
                    ok = await Api.CreateLessonAsync(workoutId, locationId, _startAt, _duration, instructorId);
                }
            }

            if (!ok) { _error = "Opslaan mislukt."; return; }
            CancelEdit();
            await LoadAsync();
        }
        finally { _busy = false; }
    }

    private async Task DeleteAsync(LessonDto l)
    {
        if (!await Api.DeleteLessonAsync(l.Id)) { _error = "Verwijderen mislukt."; return; }
        await LoadAsync();
    }
}
