<Router AppAssembly="@typeof(App).Assembly"
        AdditionalAssemblies="new[] { typeof(SportVitaal.Shared.Pages.Home).Assembly }"
        NotFoundPage="typeof(SportVitaal.Shared.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(SportVitaal.BlazerWasm.Layout.MainLayout)"/>
        <FocusOnNavigate RouteData="@routeData" Selector="h1"/>
    </Found>
</Router>
