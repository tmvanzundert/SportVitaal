@inject JwtAuthStateProvider AuthState
@inject NavigationManager Navigation

<nav class="sv-topnav">
    <div class="sv-topnav-inner">
        <a class="sv-brand" href="">
            <img class="sv-brand-icon" src="_content/SportVitaal.Shared/favicon.png" alt=""/>
            <span class="sv-brand-title">SportVitaal</span>
        </a>

        <button class="sv-toggler" type="button" title="Navigatie" @onclick="ToggleMenu">
            <span></span>
        </button>

        <div class="sv-nav-collapse @(_open ? "open" : "")">
            <ul class="sv-nav" @onclick="CloseMenu">
                <li><NavLink class="sv-nav-link" href="" Match="NavLinkMatch.All">Home</NavLink></li>
                <li><NavLink class="sv-nav-link" href="aanbod">Aanbod</NavLink></li>
                <li><NavLink class="sv-nav-link" href="rooster">Rooster</NavLink></li>
                <li><NavLink class="sv-nav-link" href="abonnementen">Abonnementen</NavLink></li>
                <li><NavLink class="sv-nav-link" href="aanmelden">Aanmelden</NavLink></li>
            </ul>

            <div class="sv-account">
                <AuthorizeView Roles="Employee">
                    <Authorized>
                        <a class="sv-account-name" href="medewerker">@(context.User.Identity?.Name ?? "Medewerker")</a>
                        <button class="sv-account-btn" @onclick="Logout">Uitloggen</button>
                    </Authorized>
                    <NotAuthorized>
                        <a class="sv-account-btn" href="medewerker/login">Medewerker login</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>

@code {
    private bool _open;

    private void ToggleMenu() => _open = !_open;

    private void CloseMenu() => _open = false;

    private async Task Logout()
    {
        _open = false;
        await AuthState.LogoutAsync();
        Navigation.NavigateTo("");
    }
}
